# Copy to .env, fill in, and NEVER commit the populated file.
#
# ---------- PICK ONE CREDENTIAL PATH ----------
#
# Path A: 1Password CLI (recommended for Simploy laptops)
# Requires `op` CLI installed + signed in (`op signin`).
# The item must expose fields labeled `username`, `password`, and optionally `peoId`.
# PRISMHR_MCP_ONEPASSWORD_VAULT=Simploy
# PRISMHR_MCP_ONEPASSWORD_ITEM_PRISMHR=PrismHR UAT

# Path B: Direct env vars (for CI, smoke tests, one-shots)
# PRISMHR_MCP_USERNAME=test-user
# PRISMHR_MCP_PASSWORD=replace-me

# ---------- ENVIRONMENT TOGGLE ----------
PRISMHR_MCP_ENVIRONMENT=uat           # uat | prod
PRISMHR_MCP_PEO_ID=TEST-PEO      # UAT default per Simploy CLAUDE.md

# Optional overrides
# PRISMHR_MCP_CACHE_DIR=C:\Users\NiharKulkarni\.simploy-mcp
# PRISMHR_MCP_SESSION_KEEPALIVE_SECONDS=600
# PRISMHR_MCP_PRISMHR_MAX_CONCURRENCY=5
